# Host ports (3000 already occupied on your server)
FRONTEND_PORT=3001
BACKEND_PORT=18000

# IMPORTANT:
# Use your real server public IP or domain, e.g.
# NEXT_PUBLIC_API_BASE_URL=http://YOUR_SERVER_IP:18000
NEXT_PUBLIC_API_BASE_URL=http://YOUR_SERVER_IP:18000

# Backend worker count (increase if CPU allows)
BACKEND_WORKERS=2

# Backend CORS configuration
# Allow frontend to access the backend API
# Replace with your actual server IP or domain
CORS_ORIGINS=http://YOUR_SERVER_IP:3001,http://localhost:3001
