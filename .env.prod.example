# ================================================================
# 生产环境变量模板
# 复制此文件为 .env.prod，填写真实值后执行：
#   docker-compose -f docker-compose.prod.yml --env-file .env.prod up -d
# ================================================================

# ── 端口映射 ─────────────────────────────────────────────────────
FRONTEND_PORT=8080
BACKEND_PORT=18000

# ── 后端 worker 数（建议 = CPU核数 × 2 + 1）─────────────────────
WORKERS=4

# ── PostgreSQL ───────────────────────────────────────────────────
POSTGRES_DB=gs1udi
POSTGRES_USER=gs1user
POSTGRES_PASSWORD=请替换为强密码

# ── JWT ──────────────────────────────────────────────────────────
# 生成方式：openssl rand -hex 32
JWT_SECRET=请替换为随机强密钥

# ── 邮件服务（Resend）────────────────────────────────────────────
RESEND_API_KEY=re_xxxxxxxxx
RESEND_FROM_EMAIL=noreply@bluesothis.com

# ── 地址配置 ─────────────────────────────────────────────────────
# 邮件中验证/重置链接的前缀（用户实际访问的地址）
FRONTEND_URL=https://your-domain.com

# 后端允许的 CORS 来源（填写前端域名，多个逗号分隔）
CORS_ORIGINS=https://your-domain.com

# ── Cookie 安全标志 ───────────────────────────────────────────────
# HTTPS 部署时设为 true；纯 HTTP（IP直接访问）时必须设为 false，
# 否则浏览器会静默丢弃 Set-Cookie 导致登录后立即掉线。
COOKIE_SECURE=false
