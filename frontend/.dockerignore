# Dependencies — installed fresh by pnpm install inside the image
node_modules/
.pnpm-store/

# Next.js build output — rebuilt inside the image
.next/
out/

# Dev secrets — never bake into image
.env
.env.*
.env.local
.env.development.local
.env.test.local
.env.production.local

# Test / coverage
coverage/
*.tsbuildinfo

# Git
.git/
.gitignore

# Misc
*.md
.DS_Store
npm-debug.log*
yarn-debug.log*
